# Firebase config for real-time collaboration (optional — the app works
# fully offline/local-only without these). Copy this file to .env.local,
# fill in the values from your Firebase project's web app settings, and
# restart `npm run dev`. See README.md's "リアルタイム共同編集のセットアップ"
# section for the full setup walkthrough.
#
# These are NOT secrets — Firebase web config is safe to expose in a
# client bundle (access control lives in firestore.rules/database.rules.json,
# not here) — but .env.local still shouldn't be committed, since it's
# meant to hold YOUR project's values, not a shared default.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Realtime Database URL — only used for live cursors/presence (see
# useLivePresence). Persistent data (bands/timetable) goes through
# Firestore and doesn't need this field.
VITE_FIREBASE_DATABASE_URL=

# Optional shared "room password" gate for joining/starting a
# collaboration room (see PasswordGate.tsx). IMPORTANT: this is baked
# into the public client bundle like every VITE_-prefixed var — anyone
# who opens devtools or views the built JS can read it. It is a soft
# deterrent against accidental access, NOT real access control.
# Leave blank to disable the gate entirely (collaboration then works
# exactly as it did before this existed).
VITE_ROOM_PASSWORD=

# Optional "admin mode" master password, entered alongside the room
# password/nickname (see PasswordGate.tsx / NicknameEntryModal.tsx).
# An admin sees a kick button next to other connected users in
# CollabControls. IMPORTANT — read before setting this: this app has no
# backend and no Firebase Auth, so this is baked into the public bundle
# exactly like VITE_ROOM_PASSWORD, AND database.rules.json can't
# actually restrict the resulting RTDB write to admins either (there's
# no server-side way to check "is this writer really an admin"). Setting
# this password only gates which users see the kick BUTTON in the UI —
# it does not, and structurally cannot, stop someone from triggering the
# same RTDB write directly via devtools. Treat it as a courtesy
# moderation affordance for a well-behaved group, not access control.
# Leave blank to disable admin mode entirely (nobody ever sees the kick
# button, same "missing env var doesn't change existing behavior"
# pattern as VITE_ROOM_PASSWORD).
VITE_ADMIN_PASSWORD=

# PAシート自動割り当て用。Google Drive APIを有効化した標準APIキーを
# 設定し、Drive APIとこのGitHub Pagesドメインだけに利用制限してください。
VITE_GOOGLE_DRIVE_API_KEY=
