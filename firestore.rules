rules_version = '2';

// live-timetable has no login system by design (see project memory:
// feedback_no-backend-static-spa) — a "room" is joined purely by knowing
// its roomId, shared as a URL (the same trust model as a Google Docs
// "anyone with the link can edit" share). These rules can't check WHO is
// writing, since there's no auth to check against; what they DO enforce
// is that every write is a well-formed room document, so one buggy
// client (or a stray script hitting the API directly) can't corrupt
// another collaborator's session with a malformed or oversized document.
// If real access control (private rooms, per-user permissions) is ever
// needed, that requires adding Firebase Auth — out of scope for this pass.
//
// One document per room (see useCollabRoom.ts) holds everything —
// eventInfo, venueHours, bands, and the timetable's days/slots — rather
// than splitting into separate collections. At this app's scale (a
// college club's one live event: dozens of bands, a handful of days)
// that's well under Firestore's 1MiB document limit, and it means a
// join/sync is exactly one read instead of coordinating several.
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isValidRoom(request.resource.data);
      allow delete: if true;
    }

    // The public pamphlet's whole reason to exist: a curated, read-only
    // document (see src/pamphlet/buildPublicPamphletDoc.ts, the ONLY
    // place that writes here) holding just what an audience should see —
    // liveName/venue/organizationName/bands/days/publishedAt. It never
    // contains Application Manager data (applicantName, raw Discord text,
    // unapproved submissions) or a Band's scheduling/administrative
    // fields (desiredTime, ngTime, raw, gearTags, etc. — see
    // src/pamphlet/types.ts's PublicBand for the exact narrowed shape),
    // because those simply never get copied into the payload in the
    // first place — this rule additionally enforces that shape server-
    // side, so even a hand-crafted write from outside this app's own UI
    // can't smuggle an extra field (like `applications`) into a doc a
    // public reader can see. Same no-auth trust model as `rooms/{roomId}`
    // above (see that collection's own comment) — write access isn't
    // restricted to "the room's admin" because there's no Auth to check
    // that against; what's restricted is the DOCUMENT SHAPE, same as
    // `rooms/{roomId}`.
    match /publicPamphlets/{circleId} {
      allow read: if true;
      allow write: if isValidPublicPamphlet(request.resource.data);
      allow delete: if true;

      function isValidPublicPamphlet(data) {
        return data.keys().hasOnly(['liveName', 'venue', 'organizationName', 'bands', 'days', 'publishedAt'])
          && data.keys().hasAll(['liveName', 'bands', 'days', 'publishedAt'])
          && data.liveName is string && data.liveName.size() < 200
          && data.bands is list && data.bands.size() < 300
          && data.days is list && data.days.size() < 20
          && data.publishedAt is int;
      }
    }

    // Generous for a college club's live-event timetable (dozens of
    // bands, a handful of days) but still bounds the size of any single
    // write — the free tier's per-document 1MiB limit is already a
    // backstop, this is a tighter, deliberately low-enough-to-notice-a-
    // bug ceiling on top of it.
    //
    // `applications` (Application Manager data) is validated only *if
    // present*, not required — a room document written by a client from
    // before this field existed won't have it yet, and requiring it would
    // reject that otherwise-valid write instead of just merging the new
    // field in going forward.
    function isValidRoom(data) {
      return data.keys().hasAll(['liveName', 'bands', 'days', 'updatedAt'])
        && data.liveName is string && data.liveName.size() < 200
        && data.bands is list && data.bands.size() < 300
        && data.days is list && data.days.size() < 20
        && data.updatedAt is int
        && (!('applications' in data) || (data.applications is list && data.applications.size() < 300));
    }
  }
}
