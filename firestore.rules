rules_version = '2';

// live-timetable has no login system by design (see project memory:
// feedback_no-backend-static-spa) — a "room" is joined purely by knowing
// its roomId, shared as a URL (the same trust model as a Google Docs
// "anyone with the link can edit" share). These rules can't check WHO is
// writing, since there's no auth to check against; what they DO enforce
// is that every write is a well-formed room document, so one buggy
// client (or a stray script hitting the API directly) can't corrupt
// another collaborator's session with a malformed or oversized document.
// If real access control (private rooms, per-user permissions) is ever
// needed, that requires adding Firebase Auth — out of scope for this pass.
//
// One document per room (see useCollabRoom.ts) holds everything —
// eventInfo, venueHours, bands, and the timetable's days/slots — rather
// than splitting into separate collections. At this app's scale (a
// college club's one live event: dozens of bands, a handful of days)
// that's well under Firestore's 1MiB document limit, and it means a
// join/sync is exactly one read instead of coordinating several.
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isValidRoom(request.resource.data);
      allow delete: if true;
    }

    // Generous for a college club's live-event timetable (dozens of
    // bands, a handful of days) but still bounds the size of any single
    // write — the free tier's per-document 1MiB limit is already a
    // backstop, this is a tighter, deliberately low-enough-to-notice-a-
    // bug ceiling on top of it.
    function isValidRoom(data) {
      return data.keys().hasAll(['liveName', 'bands', 'days', 'updatedAt'])
        && data.liveName is string && data.liveName.size() < 200
        && data.bands is list && data.bands.size() < 300
        && data.days is list && data.days.size() < 20
        && data.updatedAt is int;
    }
  }
}
