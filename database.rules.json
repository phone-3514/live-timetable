{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      "$roomId": {
        ".read": true,
        "$clientId": {
          ".write": true,
          ".validate": "newData.hasChildren(['nickname', 'isDragging']) && newData.child('nickname').isString() && newData.child('nickname').val().length < 50"
        }
      }
    }
  }
}
